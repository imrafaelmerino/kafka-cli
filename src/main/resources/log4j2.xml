<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="off" name="Adapter" packages="">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} %-5level %logger{36} %msg%n"/>
    </Console>
    <Console name="JFR" target="SYSTEM_OUT">
      <PatternLayout pattern="%msg%n"/>
    </Console>
    <File name="File" fileName="./cli.log">
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{36} - %msg%n"/>
    </File>
  </Appenders>

  <Loggers>

    <Root level="INFO">
      <AppenderRef ref="File"/>
    </Root>

    <Logger name="JFR" level="INFO" additivity="false">
      <AppenderRef ref="JFR"/>
    </Logger>

  </Loggers>
</Configuration>
